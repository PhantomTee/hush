{
  "name": "silence",
  "version": "0.1.0",
  "private": true,
  "description": "SILENCE encrypted payroll system on Solana and Arcium.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @silence/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@arcium-hq/client": "^0.9.7"
  }
}
